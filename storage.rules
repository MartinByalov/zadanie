rules_version = '2';

// Default rule - everyone has no access to anything
service firebase.storage {
  match /b/{bucket}/o {

    // За "public" папката (файлове, които ще се свалят от учениците)
    match /public/{file} {
      // Позволява само четене (сваляне) на файлове в папката public
      allow read: if true;  // всеки може да сваля файлове от "public"
      // Забранява писане (качване) на файлове в тази папка от всички освен теб
      allow write: if false;  // само ти можеш да качваш файлове в "public"
    }

    // За "uploads" папката (файлове, които учениците качват)
    match /uploads/{file} {
      // Забранява четене на тези файлове (само ти можеш да ги виждаш)
      allow read: if false;  // никой не може да чете файловете в "uploads"
      // Позволява качване на файлове от всички (учениците)
      allow write: if true;  // всеки може да качва файлове в "uploads"
    }

    // Default rule - всичко останало е забранено (по подразбиране)
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
